        <AR-PACKAGE>
          <SHORT-NAME>E2E</SHORT-NAME>
          <ELEMENTS>
            <SYSTEM-SIGNAL>
              <SHORT-NAME>E2E_EStop_Broadcast</SHORT-NAME>
              <DESC>
                <L-2 L="EN">E2E Profile: DataID(4bit)+AliveCounter(4bit)+CRC8. CAN ID: 0x001. ASIL: B. Cycle: 10ms.</L-2>
              </DESC>
            </SYSTEM-SIGNAL>
            <SYSTEM-SIGNAL>
              <SHORT-NAME>E2E_CVC_Heartbeat</SHORT-NAME>
              <DESC>
                <L-2 L="EN">E2E Profile: DataID(4bit)+AliveCounter(4bit)+CRC8. CAN ID: 0x010. ASIL: C. Cycle: 50ms.</L-2>
              </DESC>
            </SYSTEM-SIGNAL>
            <SYSTEM-SIGNAL>
              <SHORT-NAME>E2E_FZC_Heartbeat</SHORT-NAME>
              <DESC>
                <L-2 L="EN">E2E Profile: DataID(4bit)+AliveCounter(4bit)+CRC8. CAN ID: 0x011. ASIL: C. Cycle: 50ms.</L-2>
              </DESC>
            </SYSTEM-SIGNAL>
            <SYSTEM-SIGNAL>
              <SHORT-NAME>E2E_RZC_Heartbeat</SHORT-NAME>
              <DESC>
                <L-2 L="EN">E2E Profile: DataID(4bit)+AliveCounter(4bit)+CRC8. CAN ID: 0x012. ASIL: C. Cycle: 50ms.</L-2>
              </DESC>
            </SYSTEM-SIGNAL>
            <SYSTEM-SIGNAL>
