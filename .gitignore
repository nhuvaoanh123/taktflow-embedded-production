# Build artifacts
build/
*.o
*.elf
*.bin
*.hex
*.map
*.d

# Generated configs (tracked but regenerated)
# firmware/ecu/*/cfg/ — these ARE tracked

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Test reports (generated)
test/*/reports/*.xml
test/*/reports/*.html
firmware/bsw/os/bootstrap/test/*.exe
*.exe
*.bak

# Secrets
.env
*.pem
*.key
credentials.*
gateway/mosquitto/passwd

# Docker build cache
docker/*.tar

# Local private reference drops
private/

# AWS IoT Core certificates (provisioned per-device)
docker/certs/

# Temp debug/experiment directories
.tmp_*/
tmp/

# Generated codegen output (reproducible via tools/arxmlgen)
generated/

# CubeMX generated projects with build artifacts
firmware/ecu/rzc_f4/

# CubeMX generated HAL/CMSIS drivers (regenerated by CubeMX, not hand-edited)
firmware/ecu/*/cfg/Drivers/
firmware/ecu/*/cfg/Core/

# Vendor libraries (cloned repos with their own .git, not submodules)
firmware/lib/cmsis6/
firmware/lib/x-cube-azrtos-g4-full/

# SCORE HSM (separate repo with its own .git)
scorehsm/
gateway/taktflow.dbc.bak
