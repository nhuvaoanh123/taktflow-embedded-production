{% include "common/file_header.j2" %}
#include "Com.h"
#include "{{ ecu.prefix | pascal_case }}_Cfg.h"

/* ==================================================================
 * Shadow Buffers (static RAM for signal read/write)
 * ================================================================== */

/* TX signal buffers */
{% for pdu in ecu.tx_pdus %}
{% for sig in pdu.signals %}
static {{ sig | c_type }}  sig_tx_{{ sig.name | lower }};
{% endfor %}
{% endfor %}

/* RX signal buffers */
{% for pdu in ecu.rx_pdus %}
{% for sig in pdu.signals %}
static {{ sig | c_type }}  sig_rx_{{ sig.name | lower }};
{% endfor %}
{% endfor %}

/* ==================================================================
 * Signal Configuration Table
 * Maps signal ID -> bit position, size, type, parent PDU, shadow buffer
 * ================================================================== */

/* TX signal table — iterated by Com_MainFunction_Tx auto-pull */
static const Com_SignalConfigType {{ ecu.name }}_tx_signal_config[] = {
    /* id, bitPos, bitSize, type,       pduId,                      shadowBuf,       rteSignalId,  updateBit */
{% set ns = namespace(com_id=0) %}
{% for pdu in ecu.tx_pdus %}
{% for sig in pdu.signals %}
{% set sn = sig.name | lower %}
{% set is_e2e = "e_2_e_" in sn or "e2e_" in sn %}
    { {{ "%2d"|format(ns.com_id) }}u, {{ "%4d"|format(sig.bit_position) }}u, {{ "%5d"|format(sig.bit_size) }}u, {{ sig | com_type }}, {{ ecu.prefix }}_COM_TX_{{ pdu.name | upper_snake }}, &sig_tx_{{ sig.name | lower }}, {{ "COM_RTE_SIGNAL_NONE" if is_e2e else ecu.prefix ~ "_SIG_" ~ (sig.name | upper_snake) }}, COM_NO_UPDATE_BIT },
{% set ns.com_id = ns.com_id + 1 %}
{% endfor %}
{% endfor %}
};

#define {{ ecu.prefix }}_COM_TX_SIGNAL_COUNT  (sizeof({{ ecu.name }}_tx_signal_config) / sizeof({{ ecu.name }}_tx_signal_config[0]))

/* RX signal table — iterated by Com_RxIndication auto-push */
static const Com_SignalConfigType {{ ecu.name }}_rx_signal_config[] = {
    /* id, bitPos, bitSize, type,       pduId,                      shadowBuf,       rteSignalId,  updateBit */
{% set ns.com_id = 0 %}
{% for pdu in ecu.rx_pdus %}
{% for sig in pdu.signals %}
    { {{ "%2d"|format(ns.com_id) }}u, {{ "%4d"|format(sig.bit_position) }}u, {{ "%5d"|format(sig.bit_size) }}u, {{ sig | com_type }}, {{ ecu.prefix }}_COM_RX_{{ pdu.name | upper_snake }}, &sig_rx_{{ sig.name | lower }}, {{ ecu.prefix }}_SIG_{{ sig.name | upper_snake }}, COM_NO_UPDATE_BIT },
{% set ns.com_id = ns.com_id + 1 %}
{% endfor %}
{% endfor %}
};

#define {{ ecu.prefix }}_COM_RX_SIGNAL_COUNT  (sizeof({{ ecu.name }}_rx_signal_config) / sizeof({{ ecu.name }}_rx_signal_config[0]))

/* Legacy combined table — used by Com_SendSignal / Com_ReceiveSignal.
 * TX signals first (indexed by FZC_COM_SIG_* TX defines), then RX signals.
 * TODO: migrate SWC code to Rte_Write/Rte_Read and remove this table. */
static const Com_SignalConfigType {{ ecu.name }}_signal_config[] = {
{% set ns.com_id = 0 %}
{% for pdu in ecu.tx_pdus %}
{% for sig in pdu.signals %}
{% set sn = sig.name | lower %}
{% set is_e2e = "e_2_e_" in sn or "e2e_" in sn %}
    { {{ "%2d"|format(ns.com_id) }}u, {{ "%4d"|format(sig.bit_position) }}u, {{ "%5d"|format(sig.bit_size) }}u, {{ sig | com_type }}, {{ ecu.prefix }}_COM_TX_{{ pdu.name | upper_snake }}, &sig_tx_{{ sig.name | lower }}, {{ "COM_RTE_SIGNAL_NONE" if is_e2e else ecu.prefix ~ "_SIG_" ~ (sig.name | upper_snake) }}, COM_NO_UPDATE_BIT },
{% set ns.com_id = ns.com_id + 1 %}
{% endfor %}
{% endfor %}
{% for pdu in ecu.rx_pdus %}
{% for sig in pdu.signals %}
    { {{ "%2d"|format(ns.com_id) }}u, {{ "%4d"|format(sig.bit_position) }}u, {{ "%5d"|format(sig.bit_size) }}u, {{ sig | com_type }}, {{ ecu.prefix }}_COM_RX_{{ pdu.name | upper_snake }}, &sig_rx_{{ sig.name | lower }}, {{ ecu.prefix }}_SIG_{{ sig.name | upper_snake }}, COM_NO_UPDATE_BIT },
{% set ns.com_id = ns.com_id + 1 %}
{% endfor %}
{% endfor %}
};

#define {{ ecu.prefix }}_COM_SIGNAL_COUNT  (sizeof({{ ecu.name }}_signal_config) / sizeof({{ ecu.name }}_signal_config[0]))

/* ==================================================================
 * TX PDU Configuration Table
 * Maps PDU ID -> DLC, cycle time
 * PDU ID to CAN ID routing is handled by CanIf
 * ================================================================== */

static const Com_TxPduConfigType {{ ecu.name }}_tx_pdu_config[] = {
    /* pduId,                      dlc, cycleMs, txMode,              e2eProt, dataId, cntBit, crcBit */
{% for pdu in ecu.tx_pdus %}
    { {{ ecu.prefix }}_COM_TX_{{ pdu.name | upper_snake }}, {{ "%5d"|format(pdu.dlc) }}u, {{ "%5d"|format(pdu.cycle_ms) }}u, {{ "COM_TX_MODE_DIRECT  " if pdu.cycle_ms == 0 else "COM_TX_MODE_PERIODIC" }}, {{ "TRUE " if pdu.e2e_protected else "FALSE" }}, {{ "%2d"|format(pdu.e2e_data_id if pdu.e2e_data_id is not none else 0) }}u, {{ "%2d"|format(pdu.e2e_counter_bit if pdu.e2e_counter_bit is not none else 0) }}u, {{ "%2d"|format(pdu.e2e_crc_bit if pdu.e2e_crc_bit is not none else 8) }}u },   /* CAN {{ pdu.can_id | hex3 }}{{ " @satisfies " + pdu.satisfies if pdu.satisfies else "" }} */
{% endfor %}
};

#define {{ ecu.prefix }}_COM_TX_PDU_COUNT  (sizeof({{ ecu.name }}_tx_pdu_config) / sizeof({{ ecu.name }}_tx_pdu_config[0]))

/* ==================================================================
 * RX PDU Configuration Table
 * ================================================================== */

static const Com_RxPduConfigType {{ ecu.name }}_rx_pdu_config[] = {
    /* pduId,                     dlc, timeoutMs, e2eProt, dataId, maxDelta, demEvt, smValid, smInvalid */
{% for pdu in ecu.rx_pdus %}
    { {{ ecu.prefix }}_COM_RX_{{ pdu.name | upper_snake }}, {{ "%5d"|format(pdu.dlc) }}u, {{ "%5d"|format(pdu.timeout_ms) }}u, {{ "TRUE " if pdu.e2e_protected else "FALSE" }}, {{ "%2d"|format(pdu.e2e_data_id if pdu.e2e_data_id is not none else 0) }}u, {{ "%2d"|format(pdu.e2e_max_delta) }}u, {{ pdu.e2e_dem_event_id if pdu.e2e_dem_event_id >= 0 else "COM_DEM_EVENT_NONE" }}, {{ pdu.e2e_sm_window_valid }}u, {{ pdu.e2e_sm_window_invalid }}u },   /* CAN {{ pdu.can_id | hex3 }}{{ " @satisfies " + pdu.satisfies if pdu.satisfies else "" }} */
{% endfor %}
};

#define {{ ecu.prefix }}_COM_RX_PDU_COUNT  (sizeof({{ ecu.name }}_rx_pdu_config) / sizeof({{ ecu.name }}_rx_pdu_config[0]))

/* ==================================================================
 * Aggregate Com Configuration
 * ================================================================== */

const Com_ConfigType {{ ecu.name }}_com_config = {
    .signalConfig    = {{ ecu.name }}_signal_config,
    .signalCount     = (uint8){{ ecu.prefix }}_COM_SIGNAL_COUNT,
    .txSignalConfig  = {{ ecu.name }}_tx_signal_config,
    .txSignalCount   = {{ ecu.prefix }}_COM_TX_SIGNAL_COUNT,
    .rxSignalConfig  = {{ ecu.name }}_rx_signal_config,
    .rxSignalCount   = {{ ecu.prefix }}_COM_RX_SIGNAL_COUNT,
    .txPduConfig     = {{ ecu.name }}_tx_pdu_config,
    .txPduCount      = (uint8){{ ecu.prefix }}_COM_TX_PDU_COUNT,
    .rxPduConfig     = {{ ecu.name }}_rx_pdu_config,
    .rxPduCount      = (uint8){{ ecu.prefix }}_COM_RX_PDU_COUNT,
    .mainFunctionPeriodMs = {{ ecu.rte_period_ms | default(10) }}u,
};
