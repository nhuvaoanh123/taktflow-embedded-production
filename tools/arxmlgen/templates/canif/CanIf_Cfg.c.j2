{% include "common/file_header.j2" %}
#include "CanIf.h"
#include "{{ ecu.prefix | pascal_case }}_Cfg.h"

/* ==================================================================
 * TX PDU Configuration Table
 * Maps CAN TX ID → upper-layer (Com) PDU ID
 * ================================================================== */

static const CanIf_TxPduCfgType {{ ecu.name }}_tx_pdu_config[] = {
    /* canId,       upperPduId,                                      dlc */
{% for pdu in ecu.tx_pdus %}
    { {{ pdu.can_id | hex3 }}u,  {{ ecu.prefix }}_COM_TX_{{ pdu.name | upper_snake }},  {{ pdu.dlc }}u },
{% endfor %}
};

#define {{ ecu.prefix }}_CANIF_TX_PDU_COUNT  (sizeof({{ ecu.name }}_tx_pdu_config) / sizeof({{ ecu.name }}_tx_pdu_config[0]))

/* ==================================================================
 * RX PDU Configuration Table
 * Maps CAN RX ID → upper-layer (Com) PDU ID
 * ================================================================== */

static const CanIf_RxPduCfgType {{ ecu.name }}_rx_pdu_config[] = {
    /* canId,       upperPduId,                                      dlc */
{% for pdu in ecu.rx_pdus %}
    { {{ pdu.can_id | hex3 }}u,  {{ ecu.prefix }}_COM_RX_{{ pdu.name | upper_snake }},  {{ pdu.dlc }}u },
{% endfor %}
};

#define {{ ecu.prefix }}_CANIF_RX_PDU_COUNT  (sizeof({{ ecu.name }}_rx_pdu_config) / sizeof({{ ecu.name }}_rx_pdu_config[0]))

/* ==================================================================
 * Aggregate CanIf Configuration
 * ================================================================== */

const CanIf_ConfigType {{ ecu.name }}_canif_config = {
    .txPduConfig = {{ ecu.name }}_tx_pdu_config,
    .txPduCount  = (uint8_t){{ ecu.prefix }}_CANIF_TX_PDU_COUNT,
    .rxPduConfig = {{ ecu.name }}_rx_pdu_config,
    .rxPduCount  = (uint8_t){{ ecu.prefix }}_CANIF_RX_PDU_COUNT,
};
