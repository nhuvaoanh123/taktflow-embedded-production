# Environment Variables — Example
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# ─────────────────────────────────────────────
# AWS IoT Core (optional — cloud telemetry only)
# Required only for: docker/docker-compose.pi.yml (Raspberry Pi deployment)
# Not needed for: SIL, POSIX builds, unit tests
# ─────────────────────────────────────────────

AWS_IOT_ENDPOINT=your-endpoint.iot.eu-central-1.amazonaws.com
AWS_IOT_THING_NAME=taktflow-gateway-001

# Paths to X.509 certificates (generated by scripts/aws-iot-setup.sh)
AWS_IOT_CA_CERT=docker/certs/AmazonRootCA1.pem
AWS_IOT_CERT=docker/certs/device.pem.crt
AWS_IOT_PRIVATE_KEY=docker/certs/private.pem.key

# AWS Timestream (telemetry database)
AWS_REGION=eu-central-1
TIMESTREAM_DATABASE=taktflow_telemetry
TIMESTREAM_TABLE=can_signals

# ─────────────────────────────────────────────
# MQTT Broker (local or cloud)
# Default for SIL: localhost (no credentials needed)
# ─────────────────────────────────────────────

MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# ─────────────────────────────────────────────
# CAN Interface
# SIL: vcan0 (virtual)
# Physical: can0 (USB adapter) or socketcan interface name
# ─────────────────────────────────────────────

CAN_CHANNEL=vcan0
CAN_BITRATE=500000

# ─────────────────────────────────────────────
# SIL / Test
# ─────────────────────────────────────────────

SIL_TIMEOUT_S=120
SIL_LOG_LEVEL=INFO   # DEBUG | INFO | WARNING | ERROR
